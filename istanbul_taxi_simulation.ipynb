   "id": "38f03cc3-a588-4a86-a8fd-b4840d0ea2a3",
   "metadata": {},
   "source": [
    "# HYPOTHESIS 3: TRAFFIC TRAP AND INEFFICIENCY "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "df14f01a-2338-4908-9463-73068b22dfa6",
   "metadata": {},
   "source": [
    " Question: If cross-continent bridge traffic makes transitions difficult (80% reduction), how does the taxi distribution degrade? Do taxis become trapped on their respective sides?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "1ad79dc6-e105-4a22-8d70-af70a26ff121",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      ">> TEST 3: Traffic Trap (What Happens if Bridges are Congested?)\n",
      "Semt         | Normal (%) | Kriz (%) | Değişim\n",
      "----------------------------------------------\n",
      "Besiktas     | 30.1       | 35.0     | 4.9\n",
      "Kadikoy      | 26.2       | 22.5     | -3.7\n",
      "Sisli        | 35.2       | 35.2     | 0.0\n",
      "Beylikduzu   | 3.0        | 2.9      | -0.1\n",
      "Umraniye     | 5.5        | 4.4      | -1.1\n"
     ]
    }
   ],
   "source": [
    "println(\">> TEST 3: Traffic Trap (What Happens if Bridges are Congested?)\")\n",
    "\n",
    "#Creating the Crisis Matrix: Reduce cross-continent transition probabilities (Add Bias)\n",
    "P_kriz = copy(P_normal)\n",
    "ceza_katsayisi = 0.20 # Reduce transition probability by 80% \n",
    "\n",
    "for i in 1:5 \n",
    "    for j in 1:5\n",
    "        if yakalar[i] != yakalar[j] # Apply penalty if districts are on different sides\n",
    "            P_kriz[i, j] *= ceza_katsayisi\n",
    "        end\n",
    "    end\n",
    "    # Normalize the matrix \n",
    "    toplam = sum(P_kriz[i, :])\n",
    "    P_kriz[i, :] = P_kriz[i, :] ./ toplam\n",
    "end\n",
    "\n",
    "sonuc_kriz, _ = simulasyonu_calistir(P_kriz, n_taksi, n_adim)\n",
    "\n",
    "println(\"Semt         | Normal (%) | Kriz (%) | Değişim\")\n",
    "println(\"----------------------------------------------\")\n",
    "for i in 1:length(semtler)\n",
    "    normal_yuzde = round(sonuc_dagilim[i] * 100, digits=1)\n",
    "    kriz_yuzde = round(sonuc_kriz[i] * 100, digits=1)\n",
    "    degisim = round((sonuc_kriz[i] - sonuc_dagilim[i]) * 100, digits=1)\n",
    "    \n",
    "    println(rpad(semtler[i], 12), \" | \", rpad(normal_yuzde, 10), \" | \", rpad(kriz_yuzde, 8), \" | \", degisim)\n",
    "end"
   ]
  },
